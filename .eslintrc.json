{
  "extends": ["next/core-web-vitals", "next/typescript"],
  "overrides": [
    {
      "files": ["src/app/**/*.{ts,tsx}"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "paths": [
              {
                "name": "@/lib/supabase/admin",
                "message": "Use the request-scoped Supabase server client in src/app code."
              }
            ]
          }
        ]
      }
    }
  ]
}
